# AWB Management Platform - Environment Configuration
# Copy this file to .env and update with your values

# Application Settings
APP_NAME="AWB Management Platform"
APP_VERSION="1.0.0"
DEBUG=false

# API Settings
API_V1_PREFIX="/api/v1"

# AWB Editor Database (read-only connection)
AWB_DATABASE_HOST=localhost
AWB_DATABASE_PORT=5432
AWB_DATABASE_NAME=awb_editor
AWB_DATABASE_USER=postgres
AWB_DATABASE_PASSWORD=your_password_here

# Internal Database (for platform users, logs, settings)
# Leave empty to use SQLite (default: ./awb_platform.db)
# Or specify a PostgreSQL URL for production
INTERNAL_DATABASE_URL=

# Security
# IMPORTANT: Change this in production!
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Email / SMTP - envoi automatique du rapport d'activite
# Renseigner le serveur SMTP de info@elite-cargo.net (Google Workspace, OVH, cPanel...)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=info@elite-cargo.net
SMTP_PASSWORD=
SMTP_USE_TLS=true            # true = STARTTLS (port 587) ; mettre false et PORT=465 pour SSL implicite
REPORT_FROM_EMAIL=info@elite-cargo.net
REPORT_FROM_NAME=Elite Cargo
REPORT_TO_EMAILS=["l.adani@elite-cargo.net","Abdelganijacques@elite-cargo.net"]

# Jeton secret pour le déclenchement du rapport par cron externe (Railway Function)
# Générer avec: python -c "import secrets;print(secrets.token_urlsafe(32))"
REPORT_CRON_TOKEN=

# Resend - API email HTTPS (recommandé sur Railway, le SMTP y est bloqué)
# Créer une clé sur resend.com + vérifier le domaine elite-cargo.net
RESEND_API_KEY=
